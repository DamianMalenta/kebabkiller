PORT=4000
DATABASE_PATH=./data/studio.db
UPLOADS_DIR=./uploads
OUTPUT_DIR=./output

# SSL: ustawione w package.json (node --use-system-ca) — NIE wpisuj NODE_OPTIONS tutaj

# LLM — use the provider matching your key (first configured wins)
# Gemini key starts with "AQ." — put it here, NOT in OPENAI_API_KEY
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq key starts with "gsk_" — free tier: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI key starts with "sk-"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic key starts with "sk-ant-"
ANTHROPIC_API_KEY=

# Serverless GPU Engine (runcomfy | mock)
VIDEO_ENGINE=runcomfy
RUNCOMFY_API_KEY=
# V2 — deployment_id z panelu RunComfy → Deployments → Inference URL
RUNCOMFY_ENDPOINT=https://api.runcomfy.net/prod/v2/deployments/YOUR_DEPLOYMENT_ID/inference
# Opcjonalnie: polling RunComfy (domyślnie 120×5s ≈ 10 min)
# RUNCOMFY_POLL_MAX_ATTEMPTS=120
# RUNCOMFY_POLL_INTERVAL_MS=5000
# Po tylu ms in_progress bez wyniku → błąd „zawieszone” (domyślnie 10 min)
# RUNCOMFY_STALE_AFTER_MS=600000
# Co ile pollów sprawdzać /result mimo in_progress (domyślnie 12 ≈ 1 min)
# RUNCOMFY_RESULT_PROBE_EVERY=12

# Wan i2v — liczba klatek w workflow (node 54). Domyślnie 33 (~1.4 s @ 24 fps)
WAN_LENGTH=33
# KSampler denoise (0–1). Produkcja: 0.85 w profilu I2V_PRODUCTION
WAN_DENOISE=1
# SMOKE | I2V_PRODUCTION (static camera, 1 beat, niższy denoise)
I2V_PROFILE=SMOKE

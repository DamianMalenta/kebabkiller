# Port API — Vite czyta tę wartość z backend/.env (scripts/read-backend-port.mjs).
# Jeśli 4000 zajęty lokalnie, ustaw np. PORT=4001 (proxy zsynchronizuje się automatycznie).
PORT=4000
DATABASE_PATH=./data/studio.db
UPLOADS_DIR=./uploads
OUTPUT_DIR=./output

# SSL: ustawione w package.json (node --use-system-ca) — NIE wpisuj NODE_OPTIONS tutaj

# LLM — Scenarzysta + Reżyser: Groq. Reżyser fallback: OpenAI → Anthropic.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq key starts with "gsk_" — free tier: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI key starts with "sk-"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic key starts with "sk-ant-"
ANTHROPIC_API_KEY=

# Memory compaction przy akceptacji kanonu (tanie modele — osobno od Scene Director)
# MEMORY_COMPACTION_MODEL=llama-3.1-8b-instant
# MEMORY_COMPACTION_OPENAI_MODEL=gpt-4o-mini
# MEMORY_COMPACTION_TIMEOUT_MS=25000
# CANON_ACCEPTANCE_LOCK_STALE_MINUTES=5

# Serverless GPU Engine (fal | runcomfy | mock)
# Rekomendacja: VIDEO_ENGINE=fal (Kling 2.5 Pro — bez cold startu, 30-60s/klip)
VIDEO_ENGINE=fal

# ─── fal.ai (ZALECANY) ───────────────────────────────────────────────────────
# Klucz z https://fal.ai/dashboard → Keys
FAL_API_KEY=
# Model: kling-2.5-pro (domyślny) | kling-2.5-turbo (2x tańszy) | kling-2.1-pro | wan-2.1 | wan-2.2
# FAL_MODEL=kling-2.5-pro
# Polling (opcjonalne):
# FAL_POLL_INTERVAL_MS=4000
# FAL_MAX_POLL_MINUTES=10

# ─── RunComfy (legacy — WAN 2.1, długi cold start) ──────────────────────────
RUNCOMFY_API_KEY=
# V2 — deployment_id z panelu RunComfy → Deployments → Inference URL
RUNCOMFY_ENDPOINT=https://api.runcomfy.net/prod/v2/deployments/YOUR_DEPLOYMENT_ID/inference
# RUNCOMFY_POLL_MAX_ATTEMPTS=360
# RUNCOMFY_POLL_INTERVAL_MS=5000
# RUNCOMFY_STALE_AFTER_MS=1800000

# ─── Wan I2V config (używany przez RunComfy i wan-2.x na fal.ai) ────────────
# Długość: Plan odcinka (czas sceny) > WAN_LENGTH. 33 ≈ 1.4 s smoke.
WAN_LENGTH=33
# I2V_PRODUCTION (produkcja) | SMOKE (dev). I2V_PRODUCTION: denoise 0.85 w kodzie.
I2V_PROFILE=I2V_PRODUCTION
